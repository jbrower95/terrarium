{
  "name": "terrarium",
  "version": "0.1.0",
  "description": "Self-running project framework powered by GitHub Actions and Claude",
  "type": "module",
  "bin": {
    "terrarium": "./dist/packages/cli/src/index.js",
    "terrarium-owner": "./dist/packages/cli/src/owner.js",
